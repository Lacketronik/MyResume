    {
      "name": "MyResume",
      "githubUrl": "https://github.com/Lacketronik/MyResume",
      "projectDate": "2026-06-01T00:00:00",
      "descriptions": [
        {
          "description": "MyResume is a cloud-native personal portfolio project developed to demonstrate the evolution of cloud architecture from traditional deployment to serverless infrastructure. Built as an applied learning project, it was executed across four distinct phases to showcase a deep understanding of cloud migration and Automation.",
          "type": "paragraph"
        },
        {
          "description": "Phase 1: I initially built the application using a traditional virtualized stack (React/TypeScript, C# .NET Core WebAPI, and SQL) via manual cloud configuration (\"ClickOps\"). ",
          "type": "bullet"
        },
        {
          "description": "Phase 2: I then matured the infrastructure by provisioning the entire stack using Terraform for Infrastructure as Code (IaC).",
          "type": "bullet"
        },
        {
          "description": "Phase 3: To demonstrate modern cloud optimization, the project was completely refactored into a fully decoupled, Serverless architecture leveraging Azure Static Web Apps, Azure Functions, and an Azure Cosmos DB NoSQL database.",
          "type": "bullet"
        },
        {
          "description": "Phase 4: Serverless architecture entirely automated and managed with Terraform.",
          "type": "bullet"
        }
      ],
