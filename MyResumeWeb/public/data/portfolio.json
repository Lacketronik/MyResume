  "projects": [
    {
      "name": "SingaPourCast - Cloud Architecture Design",
      "githubUrl": null,
      "projectDate": "2025-03-01T00:00:00",
      "descriptions": [
        {
          "description": "SingaPourCast is a Cloud Computing module school project focused on the hands-on deployment of a weather forecasting and email subscription app on AWS. While the app itself is simple, the real goal was to build a full, production-ready infrastructure to show how real-world cloud systems work.",
          "type": "paragraph"
        },
        {
          "description": "Set up a 7-instance architecture that uses an Elastic Load Balancer (ELB) and an Auto Scaling Group (ASG) to keep the web servers highly available.",
          "type": "bullet"
        },
        {
          "description": "configured specific Route Tables and Security Group rules so the public can only access the web tier.",
          "type": "bullet"
        },
        {
          "description": "Isolated the batch (backend) server, which handles the email intervals, to only take traffic from the web servers.",
          "type": "bullet"
        },
        {
          "description": "RDS database is locked down to receive data strictly from the web and batch tiers.",
          "type": "bullet"
        }
      ],
      "videoLinks": [
        "https://youtu.be/FxMMzhjzSFg"
      ],
